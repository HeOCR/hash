{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HeOCR/public-domain-hand-written-hebrew-scans/schemas/release_recipe.schema.json",
  "title": "Release Recipe",
  "description": "Stable inputs consumed by scripts/generate_release_artifacts.py to produce NOTICE.md, CITATION.cff, and datapackage.json. Every field exercised by the generator is required; the generator uses strict recipe[\"field\"] access, so a missing key would otherwise surface as a KeyError mid-render.",
  "type": "object",
  "required": [
    "name",
    "title",
    "version",
    "description",
    "homepage",
    "repository_code",
    "authors",
    "keywords",
    "metadata_license",
    "license_urls",
    "license_names",
    "schema_urls",
    "citation_identifiers",
    "resources"
  ],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "homepage": {
      "type": "string",
      "format": "uri",
      "minLength": 1
    },
    "repository_code": {
      "type": "string",
      "format": "uri",
      "minLength": 1
    },
    "authors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "keywords": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "metadata_license": {
      "type": "object",
      "required": ["spdx", "url"],
      "additionalProperties": false,
      "properties": {
        "spdx": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri",
          "minLength": 1
        }
      }
    },
    "license_urls": {
      "type": "object",
      "propertyNames": {
        "pattern": "^(?:[A-Za-z0-9.+-]+|LicenseRef-[A-Za-z0-9.-]+)$"
      },
      "additionalProperties": {
        "type": "string",
        "format": "uri",
        "minLength": 1
      }
    },
    "license_names": {
      "type": "object",
      "propertyNames": {
        "pattern": "^(?:[A-Za-z0-9.+-]+|LicenseRef-[A-Za-z0-9.-]+)$"
      },
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "schema_urls": {
      "type": "object",
      "required": ["entry", "source"],
      "additionalProperties": false,
      "properties": {
        "entry": {
          "type": "string",
          "format": "uri",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "format": "uri",
          "minLength": 1
        }
      }
    },
    "citation_identifiers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "value"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "minLength": 1
          },
          "value": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "resources": {
      "type": "object",
      "required": ["entries", "sources"],
      "additionalProperties": false,
      "properties": {
        "entries": { "$ref": "#/$defs/resource" },
        "sources": { "$ref": "#/$defs/resource" }
      }
    }
  },
  "$defs": {
    "resource": {
      "type": "object",
      "required": ["path", "format", "mediatype", "encoding", "description"],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "format": {
          "type": "string",
          "minLength": 1
        },
        "mediatype": {
          "type": "string",
          "minLength": 1
        },
        "encoding": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
