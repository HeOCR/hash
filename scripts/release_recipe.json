  },
  "citation_identifiers": [],
  "resources": {
    "entries": {
      "path": "data/index/entries.jsonl",
      "format": "jsonl",
      "mediatype": "application/x-ndjson",
      "encoding": "utf-8",
      "description": "Scan-level index. One JSON object per page, with rights evidence, file checksums, and provenance."
    },
    "sources": {
